# ─────────────────────────────────────────────────────────────
# Base de Datos — @upds/db
# Copiar este archivo a .env y completar los valores.
# Este archivo es usado EXCLUSIVAMENTE por el CLI de Prisma
# (prisma migrate, prisma studio, etc.)
# ─────────────────────────────────────────────────────────────

# Cadena de conexión PostgreSQL para Prisma CLI.
# Formato: postgresql://<user>:<password>@<host>:<port>/<database>
# El mismo valor debe estar en apps/web/.env para que la app funcione.
DATABASE_URL=postgresql://postgres:password@localhost:5432/inventario_upds
