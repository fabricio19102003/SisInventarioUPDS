# ─────────────────────────────────────────────────────────────
# Panel Administrativo — @upds/admin
# Copiar este archivo a .env y completar los valores
# ─────────────────────────────────────────────────────────────

# ── Base de Datos ─────────────────────────────────────────────
# Cadena de conexión PostgreSQL.
# DEBE ser la misma base de datos que en apps/web/.env y packages/db/.env.
# Formato: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:password@localhost:5432/inventario_upds

# ── Autenticación (NextAuth v5) ───────────────────────────────
# Clave secreta para firmar y verificar tokens JWT.
# DEBE ser la misma clave que en apps/web/.env (AUTH_SECRET).
# Generar con: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here-change-in-production

# Permite que NextAuth confíe en los headers de proxy (x-forwarded-host).
# Establecer en true en entornos de desarrollo o detrás de un reverse proxy.
AUTH_TRUST_HOST=true
